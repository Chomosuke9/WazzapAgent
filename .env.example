# ===========================================================================
# Transport (reversed topology — post-migration)
# ===========================================================================
# After the migration the direction is REVERSED: the Node gateway is now the
# WebSocket SERVER and the Python WaSocket clients DIAL it.
#
#   Node  : listens on WS_LISTEN_PORT
#   Python: each WaSocket connects to NODE_URL, announces its tenant
#           folder_path in the `hello` handshake, and awaits `hello_ack`.

# Node server listen port (the gateway binds a ws server here). Default 3000.
WS_LISTEN_PORT=3000

# Python client dial URL (every WaSocket connects to the SAME Node server;
# the per-tenant folder_path is sent in the `hello` frame). Default below.
NODE_URL=ws://localhost:3000

# ---------------------------------------------------------------------------
# Accounts / multi-tenant config (Python side)
# ---------------------------------------------------------------------------
# Each account is one tenant folder (CONTRACT.md §8) with the layout
#   <folder_path>/{auth,db,media,stickers}
# Config sources are tried in order; first match wins:
#
#   1. ACCOUNTS_JSON — path to a JSON file: either a list
#        [{"folder_path": "...", "node_url": "..."}, ...]
#      or an object {"accounts": [...], "node_url": "..."}.
#      A per-account node_url overrides the shared NODE_URL.
#   2. FOLDER_PATHS — comma-separated tenant folders, all sharing NODE_URL.
#   3. Single-account fallback — FOLDER_PATH (or DATA_DIR, or the repo default
#      data), sharing NODE_URL. This preserves single-account boot.
#
# Single-account (leave the multi keys empty to use this fallback):
FOLDER_PATH=./data
# Multi-account (uncomment one):
# FOLDER_PATHS=./tenants/acct-a,./tenants/acct-b
# ACCOUNTS_JSON=./accounts.json
# ACCOUNTS_CONFIG is accepted as an alias for ACCOUNTS_JSON.
# ACCOUNTS_CONFIG=./accounts.json

# =========================
# Optional
# =========================

# Node gateway runtime
INSTANCE_ID=dev-gateway-1
# Pair WhatsApp WITHOUT a QR code. When set, the gateway requests an 8-char
# pairing code for this number (printed to the console/log) instead of showing
# a QR; enter it in WhatsApp > Linked Devices > Link a Device > Link with phone
# number. Digits only, with country code (e.g. 6281234567890); +, spaces, (), -
# are stripped automatically. Leave empty to use the QR flow.
WA_PAIRING_NUMBER=
# Comma-separated list of owner JIDs/numbers who can use owner-only commands
# (e.g. /broadcast, /trigger). A bare number gets @s.whatsapp.net appended.
# WhatsApp addresses group senders by an opaque LID, so the gateway resolves
# each owner number to its LID automatically on connect (so a plain phone
# number keeps working in groups). You can also paste an explicit `<lid>@lid`.
# Use the `/lid <number>` command to look up a number's LID.
# Example: 628123456789,628987654321
BOT_OWNER_JIDS=
# Require activation code before the bot responds in a chat.
# false = all chats can use the bot immediately (default)
# true  = chats must be activated with /activate <code> first
# Owners can also toggle this at runtime with `/bot-conf require-activation on|off`
# (the runtime value overrides this env default).
REQUIRE_ACTIVATION=false
# Assistant display name used by Python bridge prompt/context formatting.
# Supports comma-separated aliases for prefix mode name detection.
# First name = display name, rest = aliases that trigger the bot.
# Example: vivy,ivy,vivi,ivi,vy  (display name: vivy, aliases: ivy, vivi, etc.)
ASSISTANT_NAME=LLM
# Optional: override context time relative to UTC for prompt/history formatting.
# Example: `4` means UTC+4. Leave empty to use the server's local time.
CONTEXT_TIME_UTC_OFFSET_HOURS=
# Optional bearer token. When set, the Node WS server requires
# `Authorization: Bearer <token>` on the upgrade and rejects clients without it.
# The Python bridge reads the SAME var and sends the header automatically, so a
# token-protected gateway works end-to-end. Required for cross-host deployments.
LLM_WS_TOKEN=
# Host the Node WS server binds to. Defaults to loopback (127.0.0.1) so the
# WhatsApp control plane is NOT exposed on all interfaces. Set to 0.0.0.0 only
# for cross-host deployments (Python bridge on another machine) AND set
# LLM_WS_TOKEN when you do.
WS_BIND_HOST=127.0.0.1
# Max inbound WS frame size in bytes (DoS hardening; default 8 MiB).
WS_MAX_PAYLOAD_BYTES=8388608
DATA_DIR=./data
MEDIA_DIR=./data/media
STICKERS_DIR=./data/stickers
LOG_LEVEL=info
# Color output for BOTH processes: auto (default, color only on a TTY) | always | never.
# The standard NO_COLOR env var (any non-empty value) also disables color.
LOG_COLOR=auto
# Level for Baileys' own (very chatty) internal logger. Default 'warn' hides its
# info-level connection/keys chatter; use debug/trace to diagnose the WA socket,
# or 'silent' to mute it entirely.
BAILEYS_LOG_LEVEL=warn
WS_RECONNECT_MS=5000
WS_RECONNECT_MAX_MS=60000 # Cap for exponential reconnect backoff
WS_RECONNECT_JITTER_RATIO=0.2 # +/- jitter fraction applied to reconnect delay (0..1)
WS_HEARTBEAT_INTERVAL_MS=20000 # How often Node pings the Python bridge and the detection granularity for dead sockets
GROUP_METADATA_TIMEOUT_MS=8000
DOWNLOAD_TIMEOUT_MS=60000
SEND_TIMEOUT_MS=60000
# Drop inbound WhatsApp messages older than this (ms) on reconnect so the bot
# doesn't reply to the backlog WhatsApp flushes after coming back online.
# Default 5000 (5s). Set STALE_MESSAGE_MAX_AGE_MS=0 to disable.
STALE_MESSAGE_MAX_AGE_MS=5000
# Max concurrent message processing goroutines
UPSERT_CONCURRENCY=2
PERF_LOG_ENABLED=1
PERF_LOG_THRESHOLD_MS=400

# Python bridge runtime (ingress debounce + history window)
HISTORY_LIMIT=20
INCOMING_DEBOUNCE_SECONDS=5
INCOMING_BURST_MAX_SECONDS=20
# Maximum character length for /prompt command content (default: 4000)
PROMPT_MAX_CHARS=4000

# LLM1 (decision/gating)
# Set LLM1_ENDPOINT empty to disable LLM1 and always allow response.
# Both base URL (https://openrouter.ai/api/v1) and full URL
# (https://openrouter.ai/api/v1/chat/completions) are accepted —
# the /chat/completions suffix is stripped automatically if present.
LLM1_ENDPOINT=https://openrouter.ai/api/v1
LLM1_MODEL=openai/gpt-oss-20b
LLM1_API_KEY=
# Optional LLM1 fallback (used if primary invoke fails).
# If LLM1_FALLBACK_ENDPOINT is empty, it reuses LLM1_ENDPOINT.
LLM1_FALLBACK_ENDPOINT=
LLM1_FALLBACK_MODEL=
LLM1_FALLBACK_API_KEY=
# Optional fallback when LLM1_API_KEY is empty.
OPENAI_API_KEY=
LLM1_TEMPERATURE=0
LLM1_MAX_TOKENS=
LLM1_HISTORY_LIMIT=20
LLM1_MESSAGE_MAX_CHARS=500
LLM1_ENABLE_MEDIA_INPUT=0
LLM1_TIMEOUT=8
LLM1_SDK_MAX_RETRIES=0

# LLM2 (final responder)
# Both base URL and full URL (with /chat/completions) are accepted —
# the suffix is stripped automatically if present.
LLM2_MODEL=gpt-5.3
LLM2_ENDPOINT=
LLM2_API_KEY=
# Optional LLM2 fallback (used if primary invoke fails).
# If LLM2_FALLBACK_ENDPOINT is empty, it reuses LLM2_ENDPOINT.
LLM2_FALLBACK_MODEL=
LLM2_FALLBACK_ENDPOINT=
LLM2_FALLBACK_API_KEY=
LLM2_TEMPERATURE=0.5
LLM2_TIMEOUT=20
LLM2_RETRY_MAX=0
LLM2_RETRY_BACKOFF_SECONDS=0.8
LLM2_SDK_MAX_RETRIES=0
LLM2_MESSAGE_MAX_CHARS=0
LLM2_ENABLE_MEDIA_INPUT=1

# Shared media controls for LLM1/LLM2 multimodal input
LLM_MEDIA_MAX_ITEMS=2
LLM_MEDIA_MAX_BYTES=5242880

# Require activation code before the bot responds in a chat.
# false = all chats can use the bot immediately (default)
# true  = chats must be activated with /activate <code> first
# This env var is read by both Node.js and Python bridge.
REQUIRE_ACTIVATION=false

# Python bridge logging (LOG_COLOR / NO_COLOR above apply here too)
BRIDGE_LOG_LEVEL=info
BRIDGE_LOG_PROMPT_FULL=0
BRIDGE_LOG_EXTRAS_LIMIT=4000
# 0 = info logs compact (default), 1 = include key=val fields on INFO logs too
BRIDGE_LOG_INFO_EXTRAS=0
# fixed width for the [scope] label (group name preferred, fallback chatId)
BRIDGE_LOG_CHAT_LABEL_WIDTH=18
BRIDGE_LOG_CHAT_LABEL_DEFAULT=system
# 1 = floor noisy third-party loggers (httpx, openai, websockets, aiohttp, …)
# at WARNING so their per-request chatter stays out of the logs (default).
BRIDGE_LOG_QUIET_THIRD_PARTY=1
BRIDGE_SLOW_BATCH_LOG_MS=2000
BRIDGE_MAX_TRIGGER_BATCH_AGE_MS=45000
BRIDGE_REPLY_DEDUP_WINDOW_MS=120000
BRIDGE_REPLY_DEDUP_MIN_CHARS=24
BRIDGE_ASSISTANT_ECHO_MERGE_WINDOW_MS=180000

# Split SQLite database paths (hard cutover defaults under DATA_DIR)
# Node uses SETTINGS_DB_PATH/STATS_DB_PATH/MODERATION_DB_PATH
# Python accepts BOT_* aliases and also plain *_DB_PATH for compatibility.
# Defaults: data/settings.db, data/stats.db, data/moderation.db
SETTINGS_DB_PATH=
STATS_DB_PATH=
MODERATION_DB_PATH=
BOT_SETTINGS_DB_PATH=
BOT_STATS_DB_PATH=
BOT_MODERATION_DB_PATH=

# LLM reply format
# LLM_REPLY_INTERACTIVE=false  — plain text via sock.sendMessage (default, works on WA Web)
#                      =true   — interactive card via sendRichMessage (mobile only, WA Web incompatible)
LLM_REPLY_INTERACTIVE=

# Optional footer appended to every LLM text reply.
# In plain mode: appended as text. In interactive mode: shown in footer bar.
# Leave empty to disable.
# Example: This message was generated by AI
LLM_REPLY_FOOTER=

# Sticker creation settings (Node.js side — /sticker command)
STICKER_MAX_DURATION_SEC=6
STICKER_MAX_SIZE_KB=1024
STICKER_FPS=15
STICKER_QUALITY=75
STICKER_PACK_NAME=WazzapAgents
STICKER_EMOJI=🤖

# ---------------------------------------------------------------------------
# WazzapSubAgents integration
# ---------------------------------------------------------------------------
# Base URL of the sub-agent service (the service that executes complex tasks)
SUBAGENT_URL=http://localhost:5000
# Port for the bridge's webhook server that receives push callbacks from sub-agents.
# Multi-account: this is the BASE port — account N binds SUBAGENT_WEBHOOK_PORT + N
# (index 0 keeps the configured base, preserving single-account behaviour).
SUBAGENT_WEBHOOK_PORT=8081
# Host the local sub-agent callback webhook server binds to. Defaults to
# loopback (127.0.0.1) so the unauthenticated callback endpoint is not exposed
# on all interfaces. Set to 0.0.0.0 only when the sub-agent runs on another
# host (and prefer a firewall / reverse proxy in front of it).
SUBAGENT_WEBHOOK_HOST=127.0.0.1
# Full callback URL advertised to the sub-agent (must be reachable by sub-agent).
# When the sub-agent runs in Docker (the recommended docker-compose stack from
# WazzapSubAgents), `localhost` from inside the container is the container
# itself — use `http://host.docker.internal:8081/subagent/callback` instead so
# `complete` / `progress` callbacks reach this bridge running on the host.
SUBAGENT_WEBHOOK_URL=http://localhost:8081/subagent/callback
# Cross-process directory where the bridge stages WhatsApp media for the
# sub-agent before submitting `/execute`. Must be readable by the sub-agent
# process. For the docker-compose contract both sides bind-mount /storage
# so use `/storage/subagent_in` there. For native (non-docker) deployments
# leave this unset to fall back to `<repo_root>/data/subagent_in`, which is
# writable without root privileges.
# SUBAGENT_INPUT_STAGING_DIR=/storage/subagent_in
# Maximum file size (bytes) to inline as base64 in the /execute payload
# for cross-machine deployments. Files larger than this limit are sent as
# local paths (only works when both services share the same filesystem).
# Default 52428800 (50 MB). Set to 0 to disable base64 inlining entirely.
# SUBAGENT_MAX_INLINE_FILE_BYTES=52428800
# Maximum request body size (bytes) accepted by the bridge's webhook server
# for sub-agent callbacks (e.g. complete/progress payloads that inline
# result files as base64). Must be at least as large as the biggest callback
# payload you expect — in practice this should be >= SUBAGENT_MAX_INLINE_FILE_BYTES
# on the sub-agent side. Callbacks that exceed this limit are rejected with
# HTTP 413; the sub-agent will retry. Default 209715200 (200 MB).
# SUBAGENT_WEBHOOK_MAX_BODY_BYTES=209715200
# Maximum time (in seconds) to wait for the sub-agent to call back via the
# always-on webhook server. The webhook server auto-restarts on crash so
# this is a safety net only — if it fires, the sub-agent service itself
# has likely crashed or the network is partitioned. Default 300s (5 min).
# NOTE: This timeout resets each time a progress webhook is received
# (keepalive), so it only fires when the sub-agent goes completely silent
# for the full duration. Default 300s (5 min).
SUBAGENT_WAIT_TIMEOUT_S=300
# Absolute maximum wall-clock time (in seconds) for a sub-agent task,
# regardless of progress keepalives. Prevents a runaway sub-agent from
# keeping the bridge waiting indefinitely. Default 1800s (30 min).
# SUBAGENT_MAX_WAIT_S=1800
# Whether subagent tool is enabled by default (can be overridden per-chat via DB)
SUBAGENT_ENABLED_DEFAULT=false
# HTTP timeout (seconds) for sub-agent /execute submit requests. Default 30.
# SUBAGENT_HTTP_TIMEOUT=30
# Submit retry tunables so transient rate-limits / 5xx / network blips don't
# immediately fail the whole task. Defaults: 3 retries, 1.0s base / 30.0s max
# exponential backoff.
# SUBAGENT_SUBMIT_RETRY_MAX=3
# SUBAGENT_SUBMIT_RETRY_BASE_BACKOFF=1.0
# SUBAGENT_SUBMIT_RETRY_MAX_BACKOFF=30.0
# Bounds for sub-agent context fed back to LLM2. Defaults: 4096 / 500.
# SUBAGENT_REPORT_MAX_CHARS=4096
# SUBAGENT_PROGRESS_DETAIL_MAX_CHARS=500

# ---------------------------------------------------------------------------
# Sticker catalog storage (Python sticker_db.py + Node add/remove sticker)
# ---------------------------------------------------------------------------
# Sticker catalog DB path. Python accepts the BOT_* alias and the plain alias;
# Node mirrors the same resolution. Default: <DATA_DIR>/stickers.db.
# BOT_STICKERS_DB_PATH=
# STICKERS_DB_PATH=
# Directory where user-uploaded sticker files are stored persistently.
# Default: <DATA_DIR>/stickers_user.
# STICKER_UPLOAD_DIR=
# Sub-agent SQLite DB path (Node). Default: <DATA_DIR>/subagent.db.
# SUBAGENT_DB_PATH=

# Python sticker DB SQLite retry tunables.
# Defaults: 30s busy timeout, 8 retries, 0.05s base backoff.
# DB_BUSY_TIMEOUT_SECONDS=30
# DB_OPERATION_RETRY_MAX=8
# DB_OPERATION_RETRY_BASE_SECONDS=0.05
# Age (seconds) after which a held DB-recovery lock is treated as stale and
# may be broken. Default 120.0.
# DB_RECOVERY_LOCK_STALE_SECONDS=120
# How long (seconds) to wait for a DB-recovery lock before proceeding anyway.
# Default = 2x DB_RECOVERY_LOCK_STALE_SECONDS.
# DB_RECOVERY_LOCK_WAIT_SECONDS=240
