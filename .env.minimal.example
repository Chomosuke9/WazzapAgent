# ===========================================================================
# WazzapAgents — MINIMAL .env (for a Pterodactyl / headless deploy).
#
# Copy this file to `.env` (in /home/container) and fill in the values below.
# Both the Node gateway and the Python bridge load this file automatically.
# Everything not listed here falls back to sane defaults; the bootstrap wires
# DATA_DIR / ports / NODE_URL for you. See `.env.example` for the FULL reference.
#
# `git pull` won't touch your `.env` (it's git-ignored), so it survives updates.
# ===========================================================================

# --- Pairing (no QR) --------------------------------------------------------
# Bot's WhatsApp number, digits only with country code (e.g. 6281234567890).
# The 8-char pairing code is printed in the console: WhatsApp > Linked Devices
# > Link a Device > Link with phone number. Leave empty to pair via QR instead.
WA_PAIRING_NUMBER=6281234567890

# --- Identity ---------------------------------------------------------------
# Bot display name (comma-separated aliases also act as prefix triggers).
ASSISTANT_NAME=LLM
# Comma-separated owner numbers/JIDs (owner-only commands, e.g. /broadcast).
# @s.whatsapp.net is appended automatically if omitted. A plain phone number is
# enough — the gateway resolves its WhatsApp LID on connect so it also matches
# in groups (where senders appear as `@lid`). Look one up with `/lid <number>`.
BOT_OWNER_JIDS=628123456789

# --- LLM2 (responder — REQUIRED for the bot to actually reply) --------------
# OpenAI-compatible base URL. Leave empty to use OpenAI's default API.
LLM2_ENDPOINT=
# Responder model id.
LLM2_MODEL=gpt-4o
# API key for the LLM2 endpoint.
LLM2_API_KEY=sk-REPLACE_ME

# --- LLM1 (router — OPTIONAL, recommended for groups) -----------------------
# A cheap model that decides whether to reply in group chats (saves LLM2 cost
# on ~70-80% of messages). Leave LLM1_ENDPOINT EMPTY to DISABLE LLM1 — then
# every message goes straight to LLM2.
LLM1_ENDPOINT=
LLM1_MODEL=
LLM1_API_KEY=

# --- Optional ---------------------------------------------------------------
# Require `/activate <code>` before the bot responds in a chat (default false).
# REQUIRE_ACTIVATION=false
